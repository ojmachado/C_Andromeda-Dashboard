# ============================================================
# .env.example — Andromeda Dashboard
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA versione o .env.local com valores reais.
# ============================================================

# ------------------------------------------------------------
# SUPABASE — Banco de dados e autenticação
# Obtido em: supabase.com → Project Settings → API
# ------------------------------------------------------------
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------------------------------------------------------------
# META / FACEBOOK — App ID público (não o secret!)
# Obtido em: developers.facebook.com → App → Configurações → Básico
# O App Secret é gerenciado pelo backend/Supabase — NUNCA aqui.
# ------------------------------------------------------------
VITE_META_APP_ID=SEU_APP_ID_NUMERICO

# ------------------------------------------------------------
# APLICAÇÃO — URLs e ambiente
# ------------------------------------------------------------
# URL pública da aplicação (sem barra no final)
VITE_APP_URL=https://localhost:3000

# Ambiente: development | staging | production
VITE_APP_ENV=development

# ------------------------------------------------------------
# FEATURE FLAGS (opcional)
# ------------------------------------------------------------
# Usar Supabase como backend (true) ou localStorage (false/ausente)
VITE_USE_SUPABASE=true

# Habilitar modo demo sem autenticação real
VITE_DEMO_MODE=false
